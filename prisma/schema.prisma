generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  name      String
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  children     Child[]

  @@map("profiles")
}

model Child {
  id          String   @id @default(uuid())
  profileId   String   @map("profile_id")
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name        String
  birthDate   DateTime? @map("birth_date")
  gender      String?
  city        String?
  district    String?
  grade       Int?
  chronotype  String?
  learningStyle String? @map("learning_style")
  socialType  String?  @map("social_type")
  height      Float?
  weight      Float?
  activityLevel String? @map("activity_level")
  dominantHand String? @map("dominant_hand")
  budgetMonthly Int?   @map("budget_monthly")

  interests         String[]
  dislikedActivities String[] @map("disliked_activities")
  currentActivities  String[] @map("current_activities")
  academicStrengths  String[] @map("academic_strengths")

  intelligenceScores Json? @map("intelligence_scores")
  talentMap          Json? @map("talent_map")
  lastAiAnalysis     Json? @map("last_ai_analysis")
  lastAnalyzedAt     DateTime? @map("last_analyzed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activities    Activity[]
  achievements  Achievement[]

  @@map("children")
}

model Activity {
  id          String   @id @default(uuid())
  childId     String   @map("child_id")
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  name        String
  type        String
  days        String[]
  timeStart   String?  @map("time_start")
  timeEnd     String?  @map("time_end")
  address     String?
  price       Int?
  specialistId String? @map("specialist_id")
  isActive    Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("activities")
}

model Achievement {
  id        String   @id @default(uuid())
  childId   String   @map("child_id")
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  type      String
  title     String
  description String?
  points    Int      @default(0)
  badgeLevel String? @map("badge_level")
  earnedAt  DateTime @default(now()) @map("earned_at")

  @@map("achievements")
}
